{
  "swagger": "2.0",
  "info": {
    "title": "Orders API",
    "version": "1.0.0"
  },
  "basePath": "/v1",
  "paths": {
    "/orders/{orderId}": {
      "get": {
        "operationId": "getOrder",
        "responses": {
          "200": { "description": "ok" }
        }
      },
      "delete": {
        "operationId": "deleteOrder",
        "responses": {
          "204": { "description": "no content" }
        }
      }
    },
    "/orders": {
      "post": {
        "operationId": "createOrder",
        "responses": {
          "201": { "description": "created" }
        }
      }
    }
  }
}
